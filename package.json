{
  "name": "@anthonyotte/auth-kit",
  "version": "0.1.4",
  "description": "Drop-in email/password + OAuth + 2FA + sessions + audit-log auth for Express/Drizzle apps. Server code and React hooks only — bring your own UI.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./shared": {
      "types": "./src/shared/index.ts",
      "default": "./src/shared/index.ts"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "default": "./src/client/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "dependencies": {
    "bcrypt": "^6.0.0",
    "express-rate-limit": "^8.4.0",
    "jose": "^6.2.2",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "zxcvbn": "^4.4.2"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.39.0",
    "drizzle-zod": ">=0.7.0",
    "express": "^4.21.2",
    "react": ">=18",
    "@tanstack/react-query": ">=5",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    }
  }
}
